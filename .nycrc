{
  "all": true,
  "extension": [
    ".ts"
  ],
  "exclude": [
    "**/*.d.ts",
    "**/node_modules/**",
    "**/dist/**",
    "**/out/**",
    "src/test/**",
    "src/**/*.test.ts",
    "src/**/__tests__/**"
  ],
  "reporter": [
    "html",
    "text",
    "lcov",
    "json"
  ],
  "report-dir": "./coverage"
}
