{
  "name": "maker-language-support",
  "displayName": "MAKER Build Engine - Language Support",
  "description": "Syntax highlighting, navigation and snippets for the MAKER build engine (.mkp, .mkc, .mke)",
  "version": "1.0.0",
  "publisher": "harbour-tools",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "keywords": [
    "maker",
    "harbour",
    "build",
    "mkp",
    "mks",
    "mkc",
    "mke"
  ],
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/harbour-tools/maker-language-support"
  },
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "maker-project",
        "aliases": ["MAKER Project", "mkp"],
        "extensions": [".mkp"],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./images/mkp-light.svg",
          "dark": "./images/mkp-dark.svg"
        }
      },
      {
        "id": "maker-source",
        "aliases": ["MAKER Source", "mks"],
        "extensions": [".mks"],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./images/mkp-light.svg",
          "dark": "./images/mkp-dark.svg"
        }
      },
      {
        "id": "maker-config",
        "aliases": ["MAKER Config", "mkc"],
        "extensions": [".mkc"],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./images/mkc-light.svg",
          "dark": "./images/mkc-dark.svg"
        }
      },
      {
        "id": "maker-rules",
        "aliases": ["MAKER Rules", "mke"],
        "extensions": [".mke"],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./images/mke-light.svg",
          "dark": "./images/mke-dark.svg"
        }
      },
      {
        "id": "maker-header",
        "aliases": ["MAKER Header", "mkh"],
        "extensions": [".mkh"],
        "configuration": "./language-configuration-mkh.json",
        "icon": {
          "light": "./images/mkh-light.svg",
          "dark": "./images/mkh-dark.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "maker-project",
        "scopeName": "source.maker",
        "path": "./syntaxes/maker.tmLanguage.json"
      },
      {
        "language": "maker-source",
        "scopeName": "source.maker",
        "path": "./syntaxes/maker.tmLanguage.json"
      },
      {
        "language": "maker-config",
        "scopeName": "source.maker",
        "path": "./syntaxes/maker.tmLanguage.json"
      },
      {
        "language": "maker-rules",
        "scopeName": "source.maker",
        "path": "./syntaxes/maker.tmLanguage.json"
      },
      {
        "language": "maker-header",
        "scopeName": "source.maker.header",
        "path": "./syntaxes/maker-header.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "maker-project",
        "path": "./snippets/maker.code-snippets"
      },
      {
        "language": "maker-source",
        "path": "./snippets/maker.code-snippets"
      },
      {
        "language": "maker-config",
        "path": "./snippets/maker.code-snippets"
      },
      {
        "language": "maker-rules",
        "path": "./snippets/maker.code-snippets"
      },
      {
        "language": "maker-header",
        "path": "./snippets/maker.code-snippets"
      }
    ],
    "configuration": {
      "title": "MAKER Language Support",
      "properties": {
        "maker.rootPath": {
          "type": "string",
          "default": "",
          "description": "Caminho raiz base para resolução de arquivos fonte relativos."
        },
        "maker.enableDefinitionProvider": {
          "type": "boolean",
          "default": true,
          "description": "Habilitar navegação (Ctrl+Click) para arquivos .mkc e fontes referenciados."
        },
        "maker.enableHeaderNavigation": {
          "type": "boolean",
          "default": true,
          "description": "Habilitar navegação (Ctrl+Click) em arquivos .mkh: símbolos em [DEFINITIONS] e coordenadas em [USAGES]."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "lint:fix": "eslint src --ext ts --fix",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:unit": "jest --testPathPattern=__tests__ --coverage",
    "coverage": "jest --coverage && open coverage/index.html",
    "package": "vsce package",
    "pretest": "npm run compile"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "@types/jest": "^29.5.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.0.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "@vscode/test-electron": "^2.3.0",
    "mocha": "^10.2.0"
  }
}
